service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(authorUid) {
      return isAuthenticated() && request.auth.uid == authorUid;
    }

    // Users: Only owner can access their profile
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Articles/Ebooks: Only owner can CRUD
    match /articles/{id} {
      allow read, update, delete: if isAuthenticated() && request.auth.uid == resource.data.authorUid;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.authorUid;
    }

    match /ebooks/{id} {
      allow read, update, delete: if isAuthenticated() && request.auth.uid == resource.data.authorUid;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.authorUid;
    }
  }
}
