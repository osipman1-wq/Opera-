# ==========================================
# BACKEND CONFIGURATION
# (Server-side only)
# ==========================================
GEMINI_API_KEY=
PORT=3000
NODE_ENV=development

# ==========================================
# FRONTEND CONFIGURATION
# (Exposed to the app via VITE_ prefix)
# ==========================================
# For production (Android APK), use the full URL: https://your-backend.com
# For local dev, you can leave it empty to use relative paths via Vite proxy
VITE_BACKEND_URL=
